</Layout>

<script>
  // Lightbox triggers
  document.querySelectorAll<HTMLElement>("[data-lightbox]").forEach((el) => {
    el.addEventListener("click", () => {
      const index = parseInt(el.dataset.lightbox || "0", 10);
      window.dispatchEvent(new CustomEvent("open-lightbox", { detail: { index } }));
    });
  });

  // FAQ accordion
  document.querySelectorAll(".faq-button").forEach((button) => {
    button.addEventListener("click", () => {
      const answer = button.nextElementSibling as HTMLElement;
      const isOpen = button.getAttribute("aria-expanded") === "true";

      // Close all
      document.querySelectorAll(".faq-button").forEach((btn) => {
        btn.setAttribute("aria-expanded", "false");
        const chevron = btn.querySelector("svg");
        if (chevron) chevron.style.transform = "";
        const ans = btn.nextElementSibling as HTMLElement;
        if (ans) ans.classList.add("hidden");
      });

      // Toggle current
      if (!isOpen) {
        button.setAttribute("aria-expanded", "true");
        const chevron = button.querySelector("svg");
        if (chevron) chevron.style.transform = "rotate(180deg)";
        if (answer) answer.classList.remove("hidden");
      }
    });
  });

  // OS-aware download button
  const btn = document.getElementById("download-btn") as HTMLAnchorElement;
  const label = document.getElementById("download-label");
  const version = document.getElementById("download-version");
  const dropdownToggle = document.getElementById("download-dropdown-toggle");
  const dropdown = document.getElementById("download-dropdown");
  const dropdownList = document.getElementById("download-dropdown-list");

  const ua = navigator.userAgent.toLowerCase();
  let os = "unknown";
  if (ua.includes("mac")) os = "mac";
  else if (ua.includes("win")) os = "windows";
  else if (ua.includes("linux")) os = "linux";

  const isArm = /aarch64|arm/i.test(navigator.platform);

  const osLabels: Record<string, string> = {
    mac: "Download for macOS",
    windows: "Download for Windows",
    linux: isArm ? "Download for Linux (ARM)" : "Download for Linux (x64)",
    unknown: "Download Latest Release",
  };

  if (label) label.textContent = osLabels[os];

  // Friendly names for assets
  const assetLabels: Record<string, string> = {
    ".dmg": "macOS (DMG)",
    "-setup.exe": "Windows (EXE)",
    ".msi": "Windows (MSI)",
    "_amd64.AppImage": "Linux x64 (AppImage)",
    "_aarch64.AppImage": "Linux ARM (AppImage)",
    "_amd64.deb": "Linux x64 (DEB)",
    "_arm64.deb": "Linux ARM (DEB)",
    "x86_64.rpm": "Linux x64 (RPM)",
    "aarch64.rpm": "Linux ARM (RPM)",
  };

  const assetOrder = [".dmg", "-setup.exe", ".msi", "_amd64.AppImage", "_aarch64.AppImage", "_amd64.deb", "_arm64.deb", "x86_64.rpm", "aarch64.rpm"];
  const recommendedExts = new Set([".dmg", "-setup.exe", "_amd64.AppImage", "_aarch64.AppImage"]);

  // Toggle dropdown
  if (dropdownToggle && dropdown) {
    dropdownToggle.addEventListener("click", () => {
      const isOpen = !dropdown.classList.contains("hidden");
      dropdown.classList.toggle("hidden");
      const chevron = dropdownToggle.querySelector("svg");
      if (chevron) chevron.style.transform = isOpen ? "" : "rotate(180deg)";
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest("#download-dropdown-toggle") && !(e.target as Element).closest("#download-dropdown")) {
        dropdown.classList.add("hidden");
        const chevron = dropdownToggle.querySelector("svg");
        if (chevron) chevron.style.transform = "";
      }
    });
  }

  // Cache release data in localStorage (10 min TTL)
  const CACHE_KEY = "jean-release-v4";
  const CACHE_TTL = 10 * 60 * 1000;

  type Asset = { name: string; browser_download_url: string };
  type Release = { tag_name: string; assets: Asset[] };
  type MergedAsset = { ext: string; name: string; url: string; tag: string; isOlder: boolean };

  function mergeReleases(releases: Release[]): { latestTag: string; merged: Record<string, MergedAsset> } {
    const latestTag = releases[0]?.tag_name || "";
    const merged: Record<string, MergedAsset> = {};
    for (const ext of assetOrder) {
      for (const rel of releases) {
        const asset = (rel.assets || []).find((a) => a.name.endsWith(ext));
        if (asset) {
          merged[ext] = { ext, name: asset.name, url: asset.browser_download_url, tag: rel.tag_name, isOlder: rel.tag_name !== latestTag };
          break;
        }
      }
    }
    return { latestTag, merged };
  }

  function applyMergedData(latestTag: string, merged: Record<string, MergedAsset>) {
    if (version) version.textContent = latestTag;

    const osExtMap: Record<string, string> = { mac: ".dmg", windows: "-setup.exe", linux: isArm ? "_aarch64.AppImage" : "_amd64.AppImage" };
    const primary = merged[osExtMap[os]];
    if (primary && btn) btn.href = primary.url;

    if (dropdownList) {
      dropdownList.innerHTML = "";
      for (const ext of assetOrder) {
        const entry = merged[ext];
        if (!entry) continue;
        const link = document.createElement("a");
        link.href = entry.url;
        link.className = `flex ${entry.isOlder ? "items-start" : "items-center"} justify-between px-4 py-2.5 hover:bg-coolgray-400 transition-colors text-white`;
        const recommended = recommendedExts.has(ext);
        const badge = recommended ? `<span class="text-emerald-400 text-xs ml-2">Recommended</span>` : "";
        const building = entry.isOlder ? `<div class="text-[#FCD34D] text-xs">Currently building ${latestTag}...</div>` : "";
        const filename = entry.isOlder ? `${entry.name} (${entry.tag})` : entry.name;
        link.innerHTML = `<div><div>${assetLabels[ext] || entry.name}${badge}</div>${building}</div><span class="text-neutral-400 text-xs">${filename}</span>`;
        dropdownList.appendChild(link);
      }
    }
  }

  let cached: { ts: number; releases: Release[] } | null = null;
  try {
    const raw = localStorage.getItem(CACHE_KEY);
    if (raw) cached = JSON.parse(raw);
  } catch {}

  if (cached && Date.now() - cached.ts < CACHE_TTL) {
    const { latestTag, merged } = mergeReleases(cached.releases);
    applyMergedData(latestTag, merged);
  } else {
    fetch("https://api.github.com/repos/coollabsio/jean/releases?per_page=5")
      .then((res) => res.json())
      .then((releases: Release[]) => {
        const valid = releases.filter((r) => r.assets && r.assets.length > 0);
        if (valid.length) {
          try { localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), releases: valid })); } catch {}
          const { latestTag, merged } = mergeReleases(valid);
          applyMergedData(latestTag, merged);
        } else if (btn) {
          btn.href = "https://github.com/coollabsio/jean/releases/latest";
        }
      })
      .catch(() => {
        if (cached) {
          const { latestTag, merged } = mergeReleases(cached.releases);
          applyMergedData(latestTag, merged);
        } else if (btn) {
          btn.href = "https://github.com/coollabsio/jean/releases/latest";
        }
      });
  }
</script>
