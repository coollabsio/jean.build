---
import Layout from "../layouts/Layout.astro";
import ImageLightbox from "../components/ImageLightbox.svelte";

const screenshots = [
  { src: "/screenshots/SCR-20260304-krym.png", alt: "Project overview with worktrees, sessions, and review status" },
  { src: "/screenshots/SCR-20260304-ksgh.png", alt: "AI agent resolving merge conflicts automatically" },
  { src: "/screenshots/SCR-20260304-ksjn.png", alt: "Code review with uncommitted changes and diff view" },
  { src: "/screenshots/SCR-20260304-ksnq.png", alt: "Commit history with file changes and code diff" },
  { src: "/screenshots/SCR-20260304-kstl.png", alt: "New session dialog with PR list and context loading" },
  { src: "/screenshots/SCR-20260304-ktab.png", alt: "Magic commands palette for git operations" },
  { src: "/screenshots/SCR-20260304-ktwr.png", alt: "AI-powered code review with warnings and suggestions" },
  { src: "/screenshots/SCR-20260304-kuhk.png", alt: "Magic prompts settings with customizable AI instructions" },
];
---

<Layout>
  <!-- Hero Section -->
  <section class="pt-12 md:pt-24 pb-10 text-center px-4">
    <h1 class="text-3xl md:text-6xl font-bold tracking-tight">
      A dev environment for AI agents<span class="text-[#FCD34D]">.</span>
    </h1>
    <div class="mt-4 flex items-center justify-center gap-4 text-neutral-400">
      <span class="text-sm">Works with</span>
      <svg class="w-5 h-5" viewBox="0 0 248 248" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Claude Code"><path d="M52.4285 162.873L98.7844 136.879L99.5485 134.602L98.7844 133.334H96.4921L88.7237 132.862L62.2346 132.153L39.3113 131.207L17.0249 130.026L11.4214 128.844L6.2 121.873L6.7094 118.447L11.4214 115.257L18.171 115.847L33.0711 116.911L55.485 118.447L71.6586 119.392L95.728 121.873H99.5485L100.058 120.337L98.7844 119.392L97.7656 118.447L74.5877 102.732L49.4995 86.1905L36.3823 76.62L29.3779 71.7757L25.8121 67.2858L24.2839 57.3608L30.6515 50.2716L39.3113 50.8623L41.4763 51.4531L50.2636 58.1879L68.9842 72.7209L93.4357 90.6804L97.0015 93.6343L98.4374 92.6652L98.6571 91.9801L97.0015 89.2625L83.757 65.2772L69.621 40.8192L63.2534 30.6579L61.5978 24.632C60.9565 22.1032 60.579 20.0111 60.579 17.4246L67.8381 7.49965L71.9133 6.19995L81.7193 7.49965L85.7946 11.0443L91.9074 24.9865L101.714 46.8451L116.996 76.62L121.453 85.4816L123.873 93.6343L124.764 96.1155H126.292V94.6976L127.566 77.9197L129.858 57.3608L132.15 30.8942L132.915 23.4505L136.608 14.4708L143.994 9.62643L149.725 12.344L154.437 19.0788L153.8 23.4505L150.998 41.6463L145.522 70.1215L141.957 89.2625H143.994L146.414 86.7813L156.093 74.0206L172.266 53.698L179.398 45.6635L187.803 36.802L193.152 32.5484H203.34L210.726 43.6549L207.415 55.1159L196.972 68.3492L188.312 79.5739L175.896 96.2095L168.191 109.585L168.882 110.689L170.738 110.53L198.755 104.504L213.91 101.787L231.994 98.7149L240.144 102.496L241.036 106.395L237.852 114.311L218.495 119.037L195.826 123.645L162.07 131.592L161.696 131.893L162.137 132.547L177.36 133.925L183.855 134.279H199.774L229.447 136.524L237.215 141.605L241.8 147.867L241.036 152.711L229.065 158.737L213.019 154.956L175.45 145.977L162.587 142.787H160.805V143.85L171.502 154.366L191.242 172.089L215.82 195.011L217.094 200.682L213.91 205.172L210.599 204.699L188.949 188.394L180.544 181.069L161.696 165.118H160.422V166.772L164.752 173.152L187.803 207.771L188.949 218.405L187.294 221.832L181.308 223.959L174.813 222.777L161.187 203.754L147.305 182.486L136.098 163.345L134.745 164.2L128.075 235.42L125.019 239.082L117.887 241.8L111.902 237.31L108.718 229.984L111.902 215.452L115.722 196.547L118.779 181.541L121.58 162.873L123.291 156.636L123.14 156.219L121.773 156.449L107.699 175.752L86.304 204.699L69.3663 222.777L65.291 224.431L58.2867 220.768L58.9235 214.27L62.8713 208.48L86.304 178.705L100.44 160.155L109.551 149.507L109.462 147.967L108.959 147.924L46.6977 188.512L35.6182 189.93L30.7788 185.44L31.4156 178.115L33.7079 175.752L52.4285 162.873Z"/></svg>
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Codex"><path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/></svg>
      <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Opencode"><path fill-rule="evenodd" clip-rule="evenodd" d="M384 416H128V96H384V416ZM320 160H192V352H320V160Z"/></svg>
    </div>
    <p
      class="mt-6 text-neutral-400 max-w-4xl mx-auto text-base md:text-lg leading-relaxed"
    >
      An opinionated AI agent workspace with strong opinions about how AI-assisted
      development should work. Git worktrees, chat sessions, terminals, and GitHub
      integrations in one cohesive workflow.
    </p>
<p>Open source & free forever, backed by <a class="underline" href="/philosophy">our philosophy</a>.</p>
    <div class="mt-6 flex items-center justify-center gap-3">
      <a href="/docs" class="button inline-flex items-center gap-2">
        <svg
          class="w-4 h-4 text-[#FCD34D]"
          viewBox="0 0 256 256"
          xmlns="http://www.w3.org/2000/svg"
        >
          <g fill="currentColor">
            <path
              d="M208 32v160H72a24 24 0 0 0-24 24V56a24 24 0 0 1 24-24Z"
              opacity=".2"></path>
            <path
              d="M208 24H72a32 32 0 0 0-32 32v168a8 8 0 0 0 8 8h144a8 8 0 0 0 0-16H56a16 16 0 0 1 16-16h136a8 8 0 0 0 8-8V32a8 8 0 0 0-8-8m-8 160H72a31.82 31.82 0 0 0-16 4.29V56a16 16 0 0 1 16-16h128Z"
            ></path>
          </g>
        </svg>
        Read the docs
      </a>
    </div>

    <!-- Download Badge -->
    <div
      class="mt-6 inline-flex items-center gap-2 text-sm px-4 py-2 rounded"
    >
      <svg
        class="w-4 h-4 text-[#FCD34D]"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"
        ></path>
      </svg>
      <span class="text-neutral-400">Tested on macOS — Windows &amp; Linux <a href="https://github.com/coollabsio/jean" target="_blank" class="text-[#FCD34D] underline">testers needed</a></span>
    </div>

    <!-- Download -->
    <div class="mt-8 max-w-xl mx-auto relative">
      <div class="flex">
        <a
          id="download-btn"
          href="https://github.com/coollabsio/jean/releases/latest"
          class="font-mono bg-neutral-900 px-4 py-3 rounded-l text-xs md:text-sm text-left flex items-center justify-between hover:bg-neutral-800 transition-colors cursor-pointer flex-1"
        >
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-[#FCD34D]"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
              ></path>
            </svg>
            <span id="download-label">Download for your platform</span>
          </div>
          <span id="download-version" class="text-neutral-400 text-xs"></span>
        </a>
        <button
          id="download-dropdown-toggle"
          class="bg-neutral-900 px-3 py-3 rounded-r border-l border-coolgray-400 hover:bg-coolgray-400 transition-colors cursor-pointer"
          aria-label="Show all platforms"
        >
          <svg class="w-4 h-4 text-neutral-400 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"></path>
          </svg>
        </button>
      </div>
      <div id="download-dropdown" class="hidden absolute left-0 right-0 mt-1 bg-coolgray-300 rounded border border-coolgray-400 overflow-hidden z-50">
        <div id="download-dropdown-list" class="divide-y divide-coolgray-400 text-xs md:text-sm font-mono"></div>
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  <section class="mt-4 pb-10 px-4">
    <div class="grid grid-cols-1 gap-4">
      <button data-lightbox="0" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
        <img src={screenshots[0].src} alt={screenshots[0].alt} loading="lazy" class="w-full" />
      </button>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <button data-lightbox="1" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
          <img src={screenshots[1].src} alt={screenshots[1].alt} loading="lazy" class="w-full" />
        </button>
        <button data-lightbox="2" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
          <img src={screenshots[2].src} alt={screenshots[2].alt} loading="lazy" class="w-full" />
        </button>
        <button data-lightbox="3" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
          <img src={screenshots[3].src} alt={screenshots[3].alt} loading="lazy" class="w-full" />
        </button>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <button data-lightbox="4" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
          <img src={screenshots[4].src} alt={screenshots[4].alt} loading="lazy" class="w-full" />
        </button>
        <button data-lightbox="5" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
          <img src={screenshots[5].src} alt={screenshots[5].alt} loading="lazy" class="w-full" />
        </button>
        <button data-lightbox="6" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
          <img src={screenshots[6].src} alt={screenshots[6].alt} loading="lazy" class="w-full" />
        </button>
      </div>
      <button data-lightbox="7" class="block overflow-hidden rounded-xl border border-coolgray-300 hover:border-[#FCD34D]/40 transition-colors cursor-pointer">
        <img src={screenshots[7].src} alt={screenshots[7].alt} loading="lazy" class="w-full" />
      </button>
    </div>
    <ImageLightbox images={screenshots} client:load />
  </section>

  <!-- Features Section -->
  <section id="features" class="mt-16 pb-10 px-4">
    <h2 class="text-2xl md:text-4xl font-bold text-center">
      Everything you need<span class="text-[#FCD34D]">.</span>
    </h2>
    <p class="mt-4 text-neutral-400 text-center max-w-2xl mx-auto">
      Opinionated by design. We picked the best workflows so you can focus on shipping.
    </p>

    <dl
      class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-2xl lg:max-w-none"
    >
      <!-- Feature 1 -->
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="w-6 h-6 text-[#FCD34D] flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"
            ></path>
          </svg>
          Isolated Workspaces
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Run multiple AI agents in parallel, each in its own isolated git
            worktree. No conflicts, no interference, maximum throughput.
          </p>
        </dd>
      </div>

      <!-- Feature 2 -->
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="w-6 h-6 text-[#FCD34D] flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"
            ></path>
          </svg>
          Magic Git Commands
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Automated git workflows: review code, create commits, open PRs,
            investigate issues, and resolve merge conflicts with AI assistance.
          </p>
        </dd>
      </div>

      <!-- Feature 3 -->
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="w-6 h-6 text-[#FCD34D] flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
            ></path>
          </svg>
          Context Loading
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Load context from sessions, GitHub Issues, and Pull Requests
            directly into your AI agent's workspace. No manual copy-pasting.
          </p>
        </dd>
      </div>

      <!-- Feature 4 -->
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="w-6 h-6 text-[#FCD34D] flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"
            ></path>
          </svg>
          Worktree Management
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Automated worktree creation, archiving, and restoration. Manage
            branches and workspaces without touching the command line.
          </p>
        </dd>
      </div>

      <!-- Feature 5 -->
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="w-6 h-6 text-[#FCD34D] flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
            ></path>
          </svg>
          Automated Merging
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Merge GitHub PRs or local worktrees automatically. Built-in merge
            conflict resolution powered by AI.
          </p>
        </dd>
      </div>

      <!-- Feature 6 -->
      <div class="flex flex-col">
        <dt class="flex items-center gap-x-3 text-xl text-white">
          <svg
            class="w-6 h-6 text-[#FCD34D] flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"
            ></path>
          </svg>
          Mobile Access
        </dt>
        <dd
          class="mt-4 flex flex-auto flex-col text-sm leading-6 text-neutral-400"
        >
          <p class="flex-auto">
            Access Jean from your phone via localhost, Cloudflare Tunnel, or
            Tailscale. Monitor and manage your AI agents on the go.
          </p>
        </dd>
      </div>

      <!-- Feature 7 -->
      <div class="flex flex-col">
