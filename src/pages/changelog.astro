---
import Layout from "../layouts/Layout.astro";
import { marked } from "marked";

marked.setOptions({
  gfm: true,
});

const res = await fetch("https://api.github.com/repos/coollabsio/jean/releases", {
  headers: {
    "Accept": "application/vnd.github.v3+json",
    "User-Agent": "jean-landing",
  },
});
const releases = res.ok ? await res.json() : [];
const releaseList = Array.isArray(releases) ? releases : [];

const parsedReleases = await Promise.all(
  releaseList.map(async (release: any) => ({
    name: release.name || release.tag_name,
    tag: release.tag_name,
    date: release.published_at,
    url: release.html_url,
    body: await marked.parse(release.body || ""),
  }))
);
---

<Layout
  title="Changelog | Jean"
  description="Latest releases and updates for Jean, a dev environment for AI agents."
>
  <section class="max-w-3xl mx-auto px-4 pt-12 md:pt-24 pb-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-6xl font-bold tracking-tight text-white">
        Changelog<span class="text-[#FCD34D]">.</span>
      </h1>
      <p class="text-base pt-2 text-neutral-400">
        Latest releases from the <a href="https://github.com/coollabsio/jean" class="text-[#FCD34D] hover:underline" target="_blank" rel="noopener">GitHub repository</a>.
      </p>
    </div>

    <div class="space-y-12">
      {parsedReleases.length === 0 && (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-center text-neutral-400">
          Unable to load releases right now.
        </div>
      )}
      {parsedReleases.map((release: any) => (
        <article class="border-l-2 border-[#FCD34D]/40 pl-6 relative">
          <div class="absolute -left-[7px] top-1 w-3 h-3 rounded-full bg-[#FCD34D]" />
          <div class="flex flex-wrap items-baseline gap-3 mb-3">
            <a
              href={release.url}
              target="_blank"
              rel="noopener"
              class="text-xl md:text-2xl font-semibold text-white hover:text-[#FCD34D] transition-colors"
            >
              {release.name}
            </a>
            <time class="text-sm text-neutral-500">
              {new Date(release.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </div>
          <div
            class="prose prose-invert prose-sm max-w-none
            prose-headings:mb-3 prose-headings:mt-5 prose-headings:font-semibold prose-headings:text-white
            prose-h2:text-xl prose-h3:text-lg
            prose-p:leading-relaxed prose-p:text-neutral-300
            prose-a:text-[#FCD34D] prose-a:no-underline hover:prose-a:underline
            prose-strong:text-white
            prose-ul:list-disc prose-ul:pl-6 prose-ul:space-y-1
            prose-ol:list-decimal prose-ol:pl-6 prose-ol:space-y-1
            prose-li:text-neutral-300 marker:text-[#FCD34D]
            prose-code:rounded prose-code:bg-neutral-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-neutral-200
            prose-pre:border prose-pre:border-white/10 prose-pre:bg-neutral-900
            prose-blockquote:border-[#FCD34D]/40 prose-blockquote:text-neutral-300
            prose-hr:border-white/10"
            set:html={release.body}
          />
        </article>
      ))}
    </div>
  </section>
</Layout>
